{
  "env": {
    "ENABLE_EXPERIMENTAL_MCP_CLI": "true"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File .claude/hooks/post-edit-lint.ps1"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": ".*input.*|.*keyboard.*|.*attention.*",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File .claude/hooks/notify-input.ps1 -Title 'Claude Needs Input' -Message 'Check browser automation' -Urgent"
          }
        ]
      }
    ]
  }
}
