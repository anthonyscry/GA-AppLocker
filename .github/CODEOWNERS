# CODEOWNERS - Auto-assign reviewers for pull requests
# https://docs.github.com/en/repositories/managing-your-repositorys-settings-and-features/customizing-your-repository/about-code-owners

# Default owners for everything in the repo
*       @YOUR_GITHUB_USERNAME

# Workflow files
/.github/       @YOUR_GITHUB_USERNAME

# PowerShell source files
*.ps1   @YOUR_GITHUB_USERNAME
*.psm1  @YOUR_GITHUB_USERNAME
*.psd1  @YOUR_GITHUB_USERNAME

# .NET/C# source files
*.cs    @YOUR_GITHUB_USERNAME
*.csproj        @YOUR_GITHUB_USERNAME

# XAML UI files
*.xaml  @YOUR_GITHUB_USERNAME
